{
  "dataset": "clickstack",
  "role": "primary",
  "datasource_uid": "real-telemetry",
  "datasource_type": "prometheus",
  "query_language": "promql",
  "source": "Curated 34-metric morphology slice derived from the ClickStack OTLP sample (data/demo/clickstack/sample.tar.gz). Critical metrics use the Prometheus-exported names observed by DashForge; this is not the complete 321/368-metric catalog.",
  "prompt": "Investigate the ClickStack payment cache saturation incident: Visa validation cache size, payment transaction rate, Redis memory, cache hit ratio, evictions, and client pressure.",
  "critical_signals": [
    {"signal_type": "cache_size", "expected_metric": "visa_validation_cache_size_entries"},
    {"signal_type": "cache_hits", "expected_metric": "redis_keyspace_hits_total"},
    {"signal_type": "cache_misses", "expected_metric": "redis_keyspace_misses_total"},
    {"signal_type": "cache_evictions", "expected_metric": "redis_keys_evicted_total"},
    {"signal_type": "cache_memory_pressure", "expected_metric": "redis_memory_used_bytes"},
    {"signal_type": "client_pressure", "expected_metric": "redis_clients_connected"},
    {"signal_type": "request_latency", "expected_metric": "http_server_request_duration_seconds_bucket"}
  ],
  "metrics": [
    {"name": "redis_keyspace_hits_total", "unit": "", "type": "counter", "family": "caching", "present": true},
    {"name": "redis_keyspace_misses_total", "unit": "", "type": "counter", "family": "caching", "present": true},
    {"name": "redis_keys_evicted_total", "unit": "", "type": "counter", "family": "caching", "present": true},
    {"name": "redis_keys_expired_total", "unit": "", "type": "counter", "family": "caching", "present": true},
    {"name": "redis_db_keys", "unit": "", "type": "gauge", "family": "caching", "present": true},
    {"name": "visa_validation_cache_size_entries", "unit": "entries", "type": "gauge", "family": "caching", "present": true},
    {"name": "redis_clients_connected", "unit": "", "type": "gauge", "family": "saturation", "present": true},
    {"name": "redis_clients_blocked", "unit": "", "type": "gauge", "family": "saturation", "present": true},
    {"name": "redis_connections_rejected_total", "unit": "", "type": "counter", "family": "saturation", "present": true},
    {"name": "redis_memory_used_bytes", "unit": "By", "type": "gauge", "family": "resource_usage", "present": true},
    {"name": "redis_memory_rss_bytes", "unit": "By", "type": "gauge", "family": "resource_usage", "present": true},
    {"name": "redis_memory_fragmentation_ratio", "unit": "1", "type": "gauge", "family": "resource_usage", "present": true},
    {"name": "redis_cpu_time_seconds_total", "unit": "s", "type": "counter", "family": "resource_usage", "present": true},
    {"name": "redis_commands_processed_total", "unit": "", "type": "counter", "family": "traffic", "present": true},
    {"name": "redis_net_input_bytes_total", "unit": "By", "type": "counter", "family": "resource_usage", "present": true},
    {"name": "redis_uptime_seconds_total", "unit": "s", "type": "counter", "family": "availability", "present": true},
    {"name": "app_payment_transactions_total", "unit": "", "type": "counter", "family": "traffic", "present": true},
    {"name": "app_currency_counter_total", "unit": "", "type": "counter", "family": "traffic", "present": true},
    {"name": "http_server_request_duration_seconds_bucket", "unit": "s", "type": "histogram", "family": "latency", "present": true},
    {"name": "http_server_duration_seconds_bucket", "unit": "s", "type": "histogram", "family": "latency", "present": true},
    {"name": "http_client_request_duration_seconds_bucket", "unit": "s", "type": "histogram", "family": "latency", "present": true},
    {"name": "http_server_active_requests", "unit": "", "type": "gauge", "family": "saturation", "present": true},
    {"name": "httpcheck_error", "unit": "", "type": "gauge", "family": "errors", "present": true},
    {"name": "httpcheck_status", "unit": "1", "type": "gauge", "family": "availability", "present": true},
    {"name": "kafka_consumer_records_lag", "unit": "", "type": "gauge", "family": "backlog", "present": true},
    {"name": "container_cpu_utilization", "unit": "1", "type": "gauge", "family": "resource_usage", "present": true},
    {"name": "container_memory_usage_total", "unit": "By", "type": "gauge", "family": "resource_usage", "present": true},
    {"name": "system_memory_usage", "unit": "By", "type": "gauge", "family": "resource_usage", "present": true},
    {"name": "jvm_memory_used", "unit": "By", "type": "gauge", "family": "resource_usage", "present": true},
    {"name": "jvm_gc_duration", "unit": "s", "type": "histogram", "family": "latency", "present": true},
    {"name": "container_network_io_usage_rx_bytes", "unit": "By", "type": "counter", "family": "resource_usage", "present": true},
    {"name": "container_network_io_usage_rx_dropped", "unit": "", "type": "counter", "family": "errors", "present": true},
    {"name": "target_info", "unit": "", "type": "gauge", "family": "none", "present": true},
    {"name": "otelcol_build_info", "unit": "", "type": "gauge", "family": "none", "present": true}
  ]
}
