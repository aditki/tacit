    "InvestigationLifecycleStatus": {
      "enum": [
        "created",
        "resolving",
        "observing",
        "ranking",
        "grounding",
        "completed",
        "failed_resolution",
        "failed_observation",
        "failed_ranking",
        "failed_validation",
        "cancelled"
