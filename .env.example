# ── LLM ──────────────────────────────────────────────
LLM_PROVIDER=anthropic          # anthropic | openai | azure | ollama
LLM_API_KEY=<provider-api-key>  # API key for the chosen provider
LLM_MODEL=claude-sonnet-4-20250514  # model name (provider-specific)
LLM_API_BASE=                   # optional: custom endpoint (Azure, Ollama URL, vLLM, etc.)

# ── Grafana ──────────────────────────────────────────
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=<grafana-service-account-token>  # Service-account token with Editor role
GRAFANA_ORG_ID=1

# ── Slack ────────────────────────────────────────────
SLACK_BOT_TOKEN=<slack-bot-token>
SLACK_APP_TOKEN=<slack-app-token>        # Socket-mode token
SLACK_SIGNING_SECRET=<slack-signing-secret>

# ── Knowledge Base (optional) ───────────────────────
CONTEXT_PROVIDER=none              # none | mcp | a2a | rag_api
CONTEXT_API_KEY=                   # auth token for the context provider
# MCP provider:
CONTEXT_MCP_SERVER_URL=            # e.g. http://mcp-server.internal:8080
CONTEXT_MCP_TOOL_NAME=search      # MCP tool name for retrieval
# A2A provider:
CONTEXT_A2A_AGENT_URL=            # e.g. http://knowledge-agent.internal:9000
# RAG API provider:
CONTEXT_RAG_API_URL=              # e.g. https://rag.corp.internal/api/v1
CONTEXT_MAX_CHUNKS=10             # max context chunks per query

# ── Concurrency & Timeouts ──────────────────────────
PIPELINE_MAX_CONCURRENT=5             # max simultaneous pipeline runs
PIPELINE_TIMEOUT_SECONDS=120          # overall pipeline timeout
ADAPTER_MAX_CONCURRENT=5              # max simultaneous datasource adapter calls
ADAPTER_TIMEOUT_SECONDS=30            # per-adapter timeout
MAX_METRIC_CATALOG_SIZE=300           # total metrics sent to LLM (token budget)

# ── HTTP API Auth ───────────────────────────────────
# Local demos may leave this false. Public/private-beta deployments must set
# API_AUTH_ENABLED=true and provide a strong API_AUTH_KEY.
API_AUTH_ENABLED=false                # set true to require X-API-Key header
API_AUTH_KEY=                         # API key for HTTP API endpoints

# ── App ──────────────────────────────────────────────
LOG_LEVEL=INFO
DASHFORGE_DASHBOARD_FOLDER=DashForge   # Grafana folder for generated dashboards
DASHFORGE_DEFAULT_TIMERANGE=1h         # Default lookback window
